{
  "name": "dinheiro-cli",
  "version": "0.1.0",
  "description": "Personal finance CLI for AI agents",
  "bin": {
    "dinheiro": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint src tests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepare": "husky",
    "prepack": "npm run build",
    "prepublishOnly": "npm run format:check && npm run lint && npm test"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "drizzle-orm": "^0.40.0",
    "drizzle-zod": "^0.7.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.12.4",
    "drizzle-kit": "^0.31.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "prettier": "3.8.3",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.0.0"
  }
}
